{
  "name": "asset-management-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,css,scss}\"",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "generate:api": "openapi-generator-cli generate -i http://localhost:9000/v3/api-docs -g typescript-axios -o src/api/.generated --additional-properties=supportsES6=true,withInterfaces=true"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.4.5",
    "pinia": "^2.2.6",
    "element-plus": "^2.8.8",
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.9",
    "echarts": "^5.5.1",
    "three": "^0.170.0",
    "@amap/amap-jsapi-loader": "^1.0.1",
    "sm-crypto": "^0.3.13",
    "dayjs": "^1.11.13",
    "nprogress": "^0.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^6.0.3",
    "typescript": "^5.7.2",
    "vue-tsc": "^2.1.10",
    "@types/node": "^22.10.2",
    "@types/three": "^0.170.0",
    "@types/nprogress": "^0.2.3",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.31.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "prettier": "^3.4.2",
    "sass": "^1.82.0",
    "unplugin-auto-import": "^0.18.6",
    "unplugin-vue-components": "^0.27.5",
    "vitest": "^2.1.8",
    "@playwright/test": "^1.49.1",
    "@openapitools/openapi-generator-cli": "^2.14.0"
  }
}
