{
  "name": "asset-management-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx,.vue --fix",
    "type-check": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "api:generate": "openapi-generator-cli generate -i http://localhost:9000/v3/api-docs -g typescript-axios -o src/api/generated --additional-properties=supportsES6=true"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "echarts": "^5.5.1",
    "element-plus": "^2.8.8",
    "nprogress": "^0.2.0",
    "pinia": "^2.2.6",
    "sm-crypto": "^0.3.13",
    "three": "^0.170.0",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.15.3",
    "@playwright/test": "^1.49.1",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.31.0",
    "prettier": "^3.4.2",
    "sass": "^1.82.0",
    "typescript": "~5.6.3",
    "unplugin-auto-import": "^0.18.6",
    "unplugin-vue-components": "^0.27.5",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10"
  }
}
