<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.asset.investment.intention.mapper.InvIntentionMapper">

    <!-- 意向协议完整VO结果映射（供联表查询使用） -->
    <resultMap id="IntentionDetailMap" type="map">
        <id column="id" property="id"/>
        <result column="intention_code" property="intentionCode"/>
        <result column="intention_name" property="intentionName"/>
        <result column="project_id" property="projectId"/>
        <result column="project_name" property="projectName"/>
        <result column="merchant_id" property="merchantId"/>
        <result column="merchant_name" property="merchantName"/>
        <result column="brand_id" property="brandId"/>
        <result column="brand_name" property="brandName"/>
        <result column="status" property="status"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="contract_start" property="contractStart"/>
        <result column="contract_end" property="contractEnd"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!--
        意向协议多条件分页查询（任务 4.1）
        主表走 idx_intention_multi(project_id, status, is_deleted, created_at)
        当存在商铺相关过滤时，LEFT JOIN inv_intention_shop 进行联表过滤
        注意：DISTINCT 防止一意向多商铺时重复行
    -->
    <select id="pageQueryWithCondition"
            resultType="com.asset.investment.intention.entity.InvIntention">
        SELECT DISTINCT ii.*,
               bp.project_name,
               bm.merchant_name,
               bb.brand_name_cn AS brand_name
        FROM inv_intention ii
        LEFT JOIN biz_project  bp ON bp.id = ii.project_id  AND bp.is_deleted = 0
        LEFT JOIN biz_merchant bm ON bm.id = ii.merchant_id AND bm.is_deleted = 0
        LEFT JOIN biz_brand    bb ON bb.id = ii.brand_id    AND bb.is_deleted = 0
        <if test="q.buildingId != null or q.floorId != null or q.shopId != null
                  or (q.formatType != null and q.formatType != '')">
            LEFT JOIN inv_intention_shop iis
                ON iis.intention_id = ii.id
               AND iis.is_deleted = 0
        </if>
        WHERE ii.is_deleted = 0
          AND ii.is_current = 1
        <if test="q.projectId != null">
            AND ii.project_id = #{q.projectId}
        </if>
        <if test="q.status != null">
            AND ii.status = #{q.status}
        </if>
        <if test="q.merchantId != null">
            AND ii.merchant_id = #{q.merchantId}
        </if>
        <if test="q.brandId != null">
            AND ii.brand_id = #{q.brandId}
        </if>
        <if test="q.keyword != null and q.keyword != ''">
            AND (ii.intention_name LIKE CONCAT('%', #{q.keyword}, '%')
              OR ii.intention_code LIKE CONCAT('%', #{q.keyword}, '%'))
        </if>
        <if test="q.buildingId != null">
            AND iis.building_id = #{q.buildingId}
        </if>
        <if test="q.floorId != null">
            AND iis.floor_id = #{q.floorId}
        </if>
        <if test="q.shopId != null">
            AND iis.shop_id = #{q.shopId}
        </if>
        <if test="q.formatType != null and q.formatType != ''">
            AND iis.format_type = #{q.formatType}
        </if>
        ORDER BY ii.created_at DESC
    </select>

</mapper>
