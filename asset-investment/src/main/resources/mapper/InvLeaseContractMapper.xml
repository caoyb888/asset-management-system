<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.asset.investment.contract.mapper.InvLeaseContractMapper">

    <!-- 合同完整VO结果映射 -->
    <resultMap id="ContractDetailMap" type="map">
        <id column="id" property="id"/>
        <result column="contract_code" property="contractCode"/>
        <result column="contract_name" property="contractName"/>
        <result column="project_id" property="projectId"/>
        <result column="project_name" property="projectName"/>
        <result column="merchant_id" property="merchantId"/>
        <result column="merchant_name" property="merchantName"/>
        <result column="status" property="status"/>
        <result column="contract_start" property="contractStart"/>
        <result column="contract_end" property="contractEnd"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!--
        合同到期预警查询（利用 idx_contract_end 索引，第五阶段实现）
        SELECT * FROM inv_lease_contract
        WHERE contract_end BETWEEN ? AND ?
          AND status = 2
          AND is_current = 1
          AND is_deleted = 0
        ORDER BY contract_end ASC
    -->
    <!--
        合同多条件分页查询
        LEFT JOIN 项目/商家/品牌，返回名称字段供列表页展示
        注意：biz_brand 品牌名称列为 brand_name_cn，需 AS brand_name 映射
    -->
    <select id="pageQueryWithCondition"
            resultType="com.asset.investment.contract.entity.InvLeaseContract">
        SELECT ic.*,
               bp.project_name,
               bm.merchant_name,
               bb.brand_name_cn AS brand_name
        FROM inv_lease_contract ic
        LEFT JOIN biz_project  bp ON bp.id = ic.project_id  AND bp.is_deleted = 0
        LEFT JOIN biz_merchant bm ON bm.id = ic.merchant_id AND bm.is_deleted = 0
        LEFT JOIN biz_brand    bb ON bb.id = ic.brand_id    AND bb.is_deleted = 0
        WHERE ic.is_deleted = 0
          AND ic.is_current = 1
        <if test="q.projectId != null">
            AND ic.project_id = #{q.projectId}
        </if>
        <if test="q.status != null">
            AND ic.status = #{q.status}
        </if>
        <if test="q.merchantId != null">
            AND ic.merchant_id = #{q.merchantId}
        </if>
        <if test="q.keyword != null and q.keyword != ''">
            AND (ic.contract_name LIKE CONCAT('%', #{q.keyword}, '%')
              OR ic.contract_code LIKE CONCAT('%', #{q.keyword}, '%'))
        </if>
        ORDER BY ic.created_at DESC
    </select>

</mapper>
